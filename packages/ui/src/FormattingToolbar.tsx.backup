import { For, Show, createEffect, createMemo, createSignal, onCleanup, onMount } from "solid-js";
import {
  DEFAULT_LINE_SPACING,
  FONT_CATEGORY_LABELS,
  FONT_SIZE_OPTIONS,
  FORMATTING_TOOLBAR_KEYTIPS,
  LINE_SPACING_OPTIONS,
  MIXED_FORMATTING_LABEL,
  emptyFormattingState,
  sortFontCatalog,
  type FontCatalogEntry,
  type FontCategory,
  type FormattingState,
  type TextAlignment
} from "@monoscape/document-core";

const inlineFormattingActions = [
  {
    id: "bold",
    command: "bold",
    label: "Bold",
    shortcut: "Ctrl+B",
    ariaShortcut: "Control+B",
    content: <strong>B</strong>
  },
  {
    id: "italic",
    command: "italic",
    label: "Italic",
    shortcut: "Ctrl+I",
    ariaShortcut: "Control+I",
    content: <em>I</em>
  },
  {
    id: "underline",
    command: "underline",
    label: "Underline",
    shortcut: "Ctrl+U",
    ariaShortcut: "Control+U",
    content: <span style="text-decoration:underline">U</span>
  },
  {
    id: "strikethrough",
    command: "strikeThrough",
    label: "Strikethrough",
    shortcut: "Ctrl+Shift+X",
    ariaShortcut: "Control+Shift+X",
    content: <span style="text-decoration:line-through">S</span>
  },
  {
    id: "superscript",
    command: "superscript",
    label: "Superscript",
    shortcut: "Ctrl+.",
    ariaShortcut: "Control+.",
    content: <span style="font-size:0.8em;vertical-align:super;">x²</span>
  },
  {
    id: "subscript",
    command: "subscript",
    label: "Subscript",
    shortcut: "Ctrl+,",
    ariaShortcut: "Control+,",
    content: <span style="font-size:0.8em;vertical-align:sub;">x₂</span>
  }
] as const;

const alignmentActions: Array<{ id: TextAlignment; label: string; content: string }> = [
  { id: "left", label: "Align left", content: "≡" },
  { id: "center", label: "Align center", content: "≣" },
  { id: "right", label: "Align right", content: "☰" },
  { id: "justify", label: "Justify", content: "☷" }
];

const buttonOrder = [
  ...inlineFormattingActions.map((action) => action.id),
  ...alignmentActions.map((action) => action.id),
  "indent",
  "outdent"
] as const;

type InlineFormattingId = (typeof inlineFormattingActions)[number]["id"];
type InlineFormattingCommand = (typeof inlineFormattingActions)[number]["command"];
type ToolbarButtonId = (typeof buttonOrder)[number];
type KeytipTarget = keyof typeof FORMATTING_TOOLBAR_KEYTIPS;
type FontFilter = "all" | FontCategory;
type FontLibraryMode = "google" | null;

interface FormattingToolbarProps {
  editorRef: () => HTMLDivElement | undefined;
  registerPrimaryFocusTarget?: (focusTarget: (() => void) | null) => void;
  onNavigateOut?: (direction: "next" | "prev") => void;
  fonts: FontCatalogEntry[];
  selectedFontFamily: string | null;
  selectedFontSize: number | null;
  selectedAlignment: TextAlignment | null;
  selectedLineSpacing: number | null;
  userFonts: FontCatalogEntry[];
  fontCapabilities?: {
    searchGoogleFonts?: (query: string) => Promise<FontCatalogEntry[]>;
    uploadFonts?: boolean;
  };
  onFontFamilyChange: (fontFamily: string) => void;
  onFontSizeChange: (fontSize: number) => void;
  onAlignmentChange: (alignment: TextAlignment) => void;
  onLineSpacingChange: (lineSpacing: number) => void;
  onIndent: () => void;
  onOutdent: () => void;
  onAddCatalogFont: (font: FontCatalogEntry) => void;
  onRemoveFont: (fontId: string) => void;
  onUploadFonts: (fileList: FileList | null) => Promise<void>;
}

function formatLineSpacingValue(value: number) {
  return Number.isInteger(value)
    ? String(value)
    : value.toFixed(2).replace(/0+$/, "").replace(/\.$/, "");
}

function labelLineSpacingOption(value: number) {
  if (value === 0.5) return "0.5 · Tight";
  if (value === 1) return "1 · Single";
  if (value === 1.5) return "1.5 · Relaxed";
  if (value === 2) return "2 · Double";
  if (value === 3) return "3 · Triple";
  return formatLineSpacingValue(value);
}

export function FormattingToolbar(props: FormattingToolbarProps) {
  const [state, setState] = createSignal<FormattingState>(emptyFormattingState());
  const [fontFilter, setFontFilter] = createSignal<FontFilter>("all");
  const [fontSearchQuery, setFontSearchQuery] = createSignal("");
  const [googleQuery, setGoogleQuery] = createSignal("");
  const [googleResults, setGoogleResults] = createSignal<FontCatalogEntry[]>([]);
  const [googleSearchError, setGoogleSearchError] = createSignal("");
  const [isSearchingGoogleFonts, setIsSearchingGoogleFonts] = createSignal(false);
  const [fontSizeDraft, setFontSizeDraft] = createSignal(
    props.selectedFontSize === null ? "" : String(props.selectedFontSize)
  );
  const [fontSizeError, setFontSizeError] = createSignal("");
  const [lineSpacingDraft, setLineSpacingDraft] = createSignal(
    props.selectedLineSpacing === null ? "" : formatLineSpacingValue(props.selectedLineSpacing)
  );
  const [lineSpacingError, setLineSpacingError] = createSignal("");
  const [isFontPanelOpen, setIsFontPanelOpen] = createSignal(false);
  const [isAddMenuOpen, setIsAddMenuOpen] = createSignal(false);
  const [fontLibraryMode, setFontLibraryMode] = createSignal<FontLibraryMode>(null);
  const [isFontSizeMenuOpen, setIsFontSizeMenuOpen] = createSignal(false);
  const [isLineSpacingMenuOpen, setIsLineSpacingMenuOpen] = createSignal(false);
  const [isKeytipMode, setIsKeytipMode] = createSignal(false);

  let uploadInputRef: HTMLInputElement | undefined;
  let fontTriggerRef: HTMLButtonElement | undefined;
  let fontPanelRef: HTMLDivElement | undefined;
  let fontSearchInputRef: HTMLInputElement | undefined;
  let googleSearchInputRef: HTMLInputElement | undefined;
  let fontSizeControlRef: HTMLDivElement | undefined;
  let fontSizeInputRef: HTMLInputElement | undefined;
  let lineSpacingControlRef: HTMLDivElement | undefined;
  let lineSpacingInputRef: HTMLInputElement | undefined;
  let fontOptionRefs: HTMLButtonElement[] = [];
  let addMenuItemRefs: HTMLButtonElement[] = [];
  const buttonRefs: Partial<Record<ToolbarButtonId, HTMLButtonElement>> = {};
  let focusedButtonId: ToolbarButtonId = buttonOrder[0];

  const fontPanelId = "monoscape-font-panel";
  const fontListId = "monoscape-font-list";
  const fontSizeListId = "monoscape-font-size-list";
  const lineSpacingListId = "monoscape-line-spacing-list";

  const categoryOptions: Array<{ value: FontFilter; label: string }> = [
    { value: "all", label: "All types" },
    ...Object.entries(FONT_CATEGORY_LABELS)
      .sort((left, right) => left[1].localeCompare(right[1]))
      .map(([value, label]) => ({ value: value as FontCategory, label }))
  ];

  const selectedFontFamilyLabel = createMemo(
    () => props.selectedFontFamily ?? MIXED_FORMATTING_LABEL
  );
  const selectedFontEntry = createMemo(
    () =>
      props.selectedFontFamily === null
        ? null
        : props.fonts.find((font) => font.family === props.selectedFontFamily) ?? {
            id: props.selectedFontFamily.toLowerCase().replace(/\s+/g, "-"),
            family: props.selectedFontFamily,
            category: "custom" as const,
            source: "system" as const
          }
  );
  const selectedFontCategoryLabel = createMemo(() => {
    const font = selectedFontEntry();
    return font ? FONT_CATEGORY_LABELS[font.category] : "Mixed selection";
  });
  const knownFamilies = createMemo(() => new Set(props.fonts.map((font) => font.family)));
  const supportsLocalFonts = createMemo(() => Boolean(props.fontCapabilities?.uploadFonts));
  const supportsGoogleFonts = createMemo(() => Boolean(props.fontCapabilities?.searchGoogleFonts));
  const canAddFonts = createMemo(() => supportsLocalFonts() || supportsGoogleFonts());

  const visibleFonts = createMemo(() => {
    const currentFont =
      props.selectedFontFamily === null
        ? null
        : props.fonts.find((font) => font.family === props.selectedFontFamily);
    const filteredByCategory =
      fontFilter() === "all"
        ? props.fonts
        : props.fonts.filter((font) => font.category === fontFilter());
    const query = fontSearchQuery().trim().toLowerCase();
    const filteredFonts = query
      ? filteredByCategory.filter((font) => font.family.toLowerCase().includes(query))
      : filteredByCategory;

    if (!currentFont || filteredFonts.some((font) => font.family === currentFont.family)) {
      return filteredFonts;
    }

    return sortFontCatalog([currentFont, ...filteredFonts]);
  });

  const visibleFontSizes = createMemo(() => {
    const sizes = new Set(FONT_SIZE_OPTIONS);
    if (props.selectedFontSize !== null) {
      sizes.add(props.selectedFontSize);
    }
    const query = fontSizeDraft().trim();
    const options = [...sizes].sort((left, right) => left - right);
    return query ? options.filter((size) => `${size}`.includes(query)) : options;
  });

  const visibleLineSpacingOptions = createMemo(() => {
    const spacing = new Set(LINE_SPACING_OPTIONS);
    if (props.selectedLineSpacing !== null) {
      spacing.add(Number(formatLineSpacingValue(props.selectedLineSpacing)));
    }
    const query = lineSpacingDraft().trim();
    const options = [...spacing].sort((left, right) => left - right);
    return query
      ? options.filter((value) => labelLineSpacingOption(value).toLowerCase().includes(query.toLowerCase()))
      : options;
  });

  createEffect(() => {
    if (!isFontSizeMenuOpen()) {
      setFontSizeDraft(props.selectedFontSize === null ? "" : String(props.selectedFontSize));
      setFontSizeError("");
    }
  });

  createEffect(() => {
    if (!isLineSpacingMenuOpen()) {
      setLineSpacingDraft(
        props.selectedLineSpacing === null ? "" : formatLineSpacingValue(props.selectedLineSpacing)
      );
      setLineSpacingError("");
    }
  });

  function selectionLivesInEditor() {
    const editor = props.editorRef();
    const selection = document.getSelection();

    if (!editor || !selection?.anchorNode) {
      return false;
    }

    return editor.contains(selection.anchorNode);
  }

  function updateState() {
    if (!selectionLivesInEditor()) {
      setState(emptyFormattingState());
      return;
    }

    setState({
      bold: document.queryCommandState("bold"),
      italic: document.queryCommandState("italic"),
      underline: document.queryCommandState("underline"),
      strikethrough: document.queryCommandState("strikeThrough"),
      superscript: document.queryCommandState("superscript"),
      subscript: document.queryCommandState("subscript")
    });
  }

  function syncTabStops(nextId: ToolbarButtonId) {
    buttonOrder.forEach((buttonId) => {
      const button = buttonRefs[buttonId];
      if (button) {
        button.tabIndex = -1;
      }
    });

    focusedButtonId = nextId;
  }

  function focusButton(nextId: ToolbarButtonId) {
    syncTabStops(nextId);
    buttonRefs[nextId]?.focus();
  }

  function focusEditor() {
    const editor = props.editorRef();
    if (editor) {
      editor.focus();
      updateState();
    }
  }

  function moveFocus(delta: number) {
    const currentIndex = buttonOrder.indexOf(focusedButtonId);
    const nextIndex = (currentIndex + delta + buttonOrder.length) % buttonOrder.length;
    focusButton(buttonOrder[nextIndex]);
  }

  function navigateOut(direction: "next" | "prev") {
    props.onNavigateOut?.(direction);
  }

  function handleButtonRowKeyDown(event: KeyboardEvent) {
    if (!(event.target instanceof HTMLButtonElement)) {
      return;
    }

    const buttonId = event.target.dataset.toolbarButtonId as ToolbarButtonId | undefined;
    if (!buttonId || !buttonOrder.includes(buttonId)) {
      return;
    }

    if (event.key === "Tab") {
      event.preventDefault();
      navigateOut(event.shiftKey ? "prev" : "next");
    } else if (event.key === "ArrowRight") {
      event.preventDefault();
      if (focusedButtonId === buttonOrder[buttonOrder.length - 1]) {
        focusEditor();
      } else {
        moveFocus(1);
      }
    } else if (event.key === "ArrowLeft") {
      event.preventDefault();
      moveFocus(-1);
    } else if (event.key === "Home") {
      event.preventDefault();
      focusButton(buttonOrder[0]);
    } else if (event.key === "End") {
      event.preventDefault();
      focusButton(buttonOrder[buttonOrder.length - 1]);
    }
  }

  function keytipFor(target: KeytipTarget) {
    return FORMATTING_TOOLBAR_KEYTIPS[target];
  }

  function renderKeytip(target: KeytipTarget) {
    return (
      <Show when={isKeytipMode()}>
        <span
          aria-hidden="true"
          data-toolbar-keytip={keytipFor(target)}
          style={
            "position:absolute;top:-10px;right:-8px;z-index:30;min-width:22px;height:22px;padding:0 6px;" +
            "display:inline-flex;align-items:center;justify-content:center;border-radius:999px;" +
            "background:#005fcc;color:#ffffff;font-size:0.72rem;font-weight:700;line-height:1;" +
            "box-shadow:0 10px 18px rgba(0,95,204,0.28);pointer-events:none;"
          }
        >
          {keytipFor(target)}
        </span>
      </Show>
    );
  }

  function focusTopLevelControl(target: "fontSize" | "lineSpacing") {
    if (target === "fontSize") {
      setIsFontSizeMenuOpen(true);
      fontSizeInputRef?.focus();
      return;
    }

    setIsLineSpacingMenuOpen(true);
    lineSpacingInputRef?.focus();
  }

  function triggerToolbarButton(buttonId: ToolbarButtonId) {
    if (inlineFormattingActions.some((action) => action.id === buttonId)) {
      const action = inlineFormattingActions.find((entry) => entry.id === buttonId);
      if (action) {
        execInlineFormat(action.command);
      }
      return true;
    }

    if (alignmentActions.some((action) => action.id === buttonId)) {
      commitAlignmentChange(buttonId as TextAlignment);
      return true;
    }

    if (buttonId === "indent") {
      commitIndent();
      return true;
    }

    if (buttonId === "outdent") {
      commitOutdent();
      return true;
    }

    return false;
  }

  function activateKeytip(key: string) {
    switch (key) {
      case keytipFor("fontFamily"):
        if (isFontPanelOpen()) {
          focusFontSearch();
        } else {
          openFontPanel();
        }
        return true;
      case keytipFor("fontSize"):
        focusTopLevelControl("fontSize");
        return true;
      case keytipFor("lineSpacing"):
        focusTopLevelControl("lineSpacing");
        return true;
      case keytipFor("bold"):
        return triggerToolbarButton("bold");
      case keytipFor("italic"):
        return triggerToolbarButton("italic");
      case keytipFor("underline"):
        return triggerToolbarButton("underline");
      case keytipFor("strikethrough"):
        return triggerToolbarButton("strikethrough");
      case keytipFor("superscript"):
        return triggerToolbarButton("superscript");
      case keytipFor("subscript"):
        return triggerToolbarButton("subscript");
      case keytipFor("left"):
        return triggerToolbarButton("left");
      case keytipFor("center"):
        return triggerToolbarButton("center");
      case keytipFor("right"):
        return triggerToolbarButton("right");
      case keytipFor("justify"):
        return triggerToolbarButton("justify");
      case keytipFor("indent"):
        return triggerToolbarButton("indent");
      case keytipFor("outdent"):
        return triggerToolbarButton("outdent");
      default:
        return false;
    }
  }

  function execInlineFormat(command: InlineFormattingCommand) {
    const editor = props.editorRef();
    if (editor) {
      editor.focus();
    }
    document.execCommand(command);
    updateState();
  }

  function commitFontFamilyChange(fontFamily: string) {
    props.onFontFamilyChange(fontFamily);
    queueMicrotask(() => focusEditor());
  }

  function commitFontSizeChange(fontSize: number, options?: { focusEditor?: boolean }) {
    props.onFontSizeChange(fontSize);
    setIsFontSizeMenuOpen(false);
    if (options?.focusEditor ?? true) {
      queueMicrotask(() => focusEditor());
    }
  }

  function commitAlignmentChange(alignment: TextAlignment) {
    props.onAlignmentChange(alignment);
    queueMicrotask(() => focusEditor());
  }

  function commitLineSpacingChange(lineSpacing: number, options?: { focusEditor?: boolean }) {
    props.onLineSpacingChange(lineSpacing);
    setIsLineSpacingMenuOpen(false);
    if (options?.focusEditor ?? true) {
      queueMicrotask(() => focusEditor());
    }
  }

  function commitIndent() {
    props.onIndent();
    queueMicrotask(() => focusEditor());
  }

  function commitOutdent() {
    props.onOutdent();
    queueMicrotask(() => focusEditor());
  }

  async function handleGoogleFontSearch() {
    const searchGoogleFonts = props.fontCapabilities?.searchGoogleFonts;
    const query = googleQuery().trim();

    if (!searchGoogleFonts || !query) {
      setGoogleResults([]);
      setGoogleSearchError(query ? "" : "Enter a family name to search.");
      return;
    }

    setIsSearchingGoogleFonts(true);
    setGoogleSearchError("");

    try {
      const results = sortFontCatalog(await searchGoogleFonts(query));
      setGoogleResults(results);

      if (!results.length) {
        setGoogleSearchError("No validated Google Fonts matched that search.");
      }
    } catch (error) {
      console.warn("Unable to search Google Fonts.", error);
      setGoogleResults([]);
      setGoogleSearchError("Google Fonts search is unavailable right now.");
    } finally {
      setIsSearchingGoogleFonts(false);
    }
  }

  function handleFontSizeCommit(value: string, options?: { focusEditor?: boolean }) {
    const trimmed = value.trim();
    if (!trimmed) {
      setFontSizeDraft(props.selectedFontSize === null ? "" : String(props.selectedFontSize));
      setFontSizeError("");
      return;
    }

    const parsed = Number(trimmed);
    if (Number.isNaN(parsed)) {
      setFontSizeError("Font size must be a number.");
      return;
    }

    const normalized = Math.round(parsed);
    if (normalized < 4 || normalized > 72) {
      setFontSizeError("Font size must be between 4 and 72 points.");
      return;
    }

    setFontSizeError("");
    setFontSizeDraft(String(normalized));
    commitFontSizeChange(normalized, options);
  }

  function handleLineSpacingCommit(value: string, options?: { focusEditor?: boolean }) {
    const trimmed = value.trim();
    if (!trimmed) {
      setLineSpacingDraft(
        props.selectedLineSpacing === null ? "" : formatLineSpacingValue(props.selectedLineSpacing)
      );
      setLineSpacingError("");
      return;
    }

    const parsed = Number(trimmed);
    if (Number.isNaN(parsed)) {
      setLineSpacingError("Line spacing must be a number.");
      return;
    }

    if (parsed < 0.5 || parsed > 6) {
      setLineSpacingError("Line spacing must be between 0.5 and 6.");
      return;
    }

    const normalized = Number(formatLineSpacingValue(parsed));
    setLineSpacingError("");
    setLineSpacingDraft(formatLineSpacingValue(normalized));
    commitLineSpacingChange(normalized, options);
  }

  function handleRemoveFont(fontId: string, fontFamily: string) {
    const confirmed = window.confirm(
      `Remove "${fontFamily}" from your library? This cannot be undone.`
    );

    if (confirmed) {
      props.onRemoveFont(fontId);
    }
  }

  function closeFontPanel() {
    setIsFontPanelOpen(false);
    setIsAddMenuOpen(false);
    setFontLibraryMode(null);
    setGoogleSearchError("");
  }

  function focusFontSearch() {
    queueMicrotask(() => fontSearchInputRef?.focus());
  }

  function openFontPanel() {
    setFontSearchQuery("");
    setIsFontPanelOpen(true);
    setIsAddMenuOpen(false);
    focusFontSearch();
  }

  function toggleFontPanel() {
    if (isFontPanelOpen()) {
      closeFontPanel();
      fontTriggerRef?.focus();
      return;
    }

    openFontPanel();
  }

  function toggleAddMenu() {
    if (!canAddFonts()) {
      return;
    }

    setIsAddMenuOpen((open) => !open);
  }

  function selectFont(fontFamily: string) {
    commitFontFamilyChange(fontFamily);
    setFontLibraryMode(null);
    setIsAddMenuOpen(false);
    closeFontPanel();
  }

  async function handleUploadedFonts(fileList: FileList | null) {
    await props.onUploadFonts(fileList);
    if (uploadInputRef) {
      uploadInputRef.value = "";
    }
    queueMicrotask(() => focusEditor());
  }

  function focusGoogleSearch() {
    queueMicrotask(() => googleSearchInputRef?.focus());
  }

  function handleAddMenuChoice(source: "local" | "google") {
    if (source === "local") {
      setIsAddMenuOpen(false);
      if (supportsLocalFonts()) {
        uploadInputRef?.click();
      } else {
        setGoogleSearchError("Local font installs are only available in the desktop app.");
      }
      return;
    }

    setIsAddMenuOpen(false);
    if (supportsGoogleFonts()) {
      setFontLibraryMode("google");
      setGoogleSearchError("");
      focusGoogleSearch();
    } else {
      setGoogleSearchError("Google Fonts search is only available in the desktop app.");
    }
  }

  function handleFontTriggerKeyDown(event: KeyboardEvent) {
    if (event.key === "Tab") {
      event.preventDefault();
      navigateOut(event.shiftKey ? "prev" : "next");
    } else if (event.key === "ArrowDown" || event.key === "Enter" || event.key === " ") {
      event.preventDefault();
      if (!isFontPanelOpen()) {
        openFontPanel();
      } else {
        focusFontSearch();
      }
    } else if (event.key === "Escape" && isFontPanelOpen()) {
      event.preventDefault();
      closeFontPanel();
      fontTriggerRef?.focus();
    }
  }

  function handleFontPanelKeyDown(event: KeyboardEvent) {
    if (event.key === "Escape") {
      event.preventDefault();
      closeFontPanel();
      fontTriggerRef?.focus();
    }
  }

  function handleFontSearchKeyDown(event: KeyboardEvent) {
    if (event.key === "ArrowDown") {
      event.preventDefault();
      fontOptionRefs[0]?.focus();
    } else if (event.key === "Escape") {
      event.preventDefault();
      closeFontPanel();
      fontTriggerRef?.focus();
    }
  }

  function handleFontOptionKeyDown(event: KeyboardEvent) {
    const target = event.currentTarget as HTMLButtonElement;
    const currentIndex = fontOptionRefs.indexOf(target);
    if (currentIndex === -1) {
      return;
    }

    if (event.key === "ArrowDown") {
      event.preventDefault();
      fontOptionRefs[(currentIndex + 1) % fontOptionRefs.length]?.focus();
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      if (currentIndex === 0) {
        fontSearchInputRef?.focus();
        return;
      }
      fontOptionRefs[currentIndex - 1]?.focus();
    } else if (event.key === "Home") {
      event.preventDefault();
      fontOptionRefs[0]?.focus();
    } else if (event.key === "End") {
      event.preventDefault();
      fontOptionRefs[fontOptionRefs.length - 1]?.focus();
    }
  }

  function handleAddMenuKeyDown(event: KeyboardEvent) {
    const target = event.currentTarget as HTMLButtonElement;
    const currentIndex = addMenuItemRefs.indexOf(target);
    if (currentIndex === -1) {
      return;
    }

    if (event.key === "ArrowDown") {
      event.preventDefault();
      addMenuItemRefs[(currentIndex + 1) % addMenuItemRefs.length]?.focus();
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      addMenuItemRefs[(currentIndex - 1 + addMenuItemRefs.length) % addMenuItemRefs.length]?.focus();
    } else if (event.key === "Escape") {
      event.preventDefault();
      setIsAddMenuOpen(false);
    }
  }

  function handleFontSizeInputKeyDown(event: KeyboardEvent) {
    if (event.key === "Tab") {
      event.preventDefault();
      handleFontSizeCommit((event.currentTarget as HTMLInputElement).value, { focusEditor: false });
      navigateOut(event.shiftKey ? "prev" : "next");
    } else if (event.key === "ArrowDown") {
      event.preventDefault();
      setIsFontSizeMenuOpen(true);
    } else if (event.key === "Enter") {
      event.preventDefault();
      handleFontSizeCommit((event.currentTarget as HTMLInputElement).value);
    } else if (event.key === "Escape") {
      event.preventDefault();
      setIsFontSizeMenuOpen(false);
      setFontSizeDraft(props.selectedFontSize === null ? "" : String(props.selectedFontSize));
      setFontSizeError("");
    }
  }

  function handleLineSpacingInputKeyDown(event: KeyboardEvent) {
    if (event.key === "Tab") {
      event.preventDefault();
      handleLineSpacingCommit((event.currentTarget as HTMLInputElement).value, { focusEditor: false });
      navigateOut(event.shiftKey ? "prev" : "next");
    } else if (event.key === "ArrowDown") {
      event.preventDefault();
      setIsLineSpacingMenuOpen(true);
    } else if (event.key === "Enter") {
      event.preventDefault();
      handleLineSpacingCommit((event.currentTarget as HTMLInputElement).value);
    } else if (event.key === "Escape") {
      event.preventDefault();
      setIsLineSpacingMenuOpen(false);
      setLineSpacingDraft(
        props.selectedLineSpacing === null ? "" : formatLineSpacingValue(props.selectedLineSpacing)
      );
      setLineSpacingError("");
    }
  }

  onMount(() => {
    props.registerPrimaryFocusTarget?.(() => fontTriggerRef?.focus());

    const handlePointerDown = (event: MouseEvent) => {
      setIsKeytipMode(false);
      const target = event.target;
      if (!(target instanceof Node)) {
        return;
      }

      if (!fontPanelRef?.contains(target) && !fontTriggerRef?.contains(target)) {
        closeFontPanel();
      }

      if (!fontSizeControlRef?.contains(target)) {
        setIsFontSizeMenuOpen(false);
      }

      if (!lineSpacingControlRef?.contains(target)) {
        setIsLineSpacingMenuOpen(false);
      }
    };

    const clearKeytips = () => setIsKeytipMode(false);
    const handleDocumentKeyDown = (event: KeyboardEvent) => {
      if (event.key === "Alt" && !event.ctrlKey && !event.metaKey) {
        event.preventDefault();
        setIsKeytipMode(true);
        return;
      }

      if (event.key === "Escape" && isKeytipMode()) {
        setIsKeytipMode(false);
        return;
      }

      if (!event.altKey || event.ctrlKey || event.metaKey) {
        return;
      }

      const normalizedKey = event.key.length === 1 ? event.key.toUpperCase() : "";
      if (!normalizedKey) {
        return;
      }

      if (activateKeytip(normalizedKey)) {
        event.preventDefault();
        setIsKeytipMode(false);
      }
    };
    const handleDocumentKeyUp = (event: KeyboardEvent) => {
      if (event.key === "Alt") {
        setIsKeytipMode(false);
      }
    };

    document.addEventListener("selectionchange", updateState);
    document.addEventListener("mousedown", handlePointerDown);
    document.addEventListener("keydown", handleDocumentKeyDown, true);
    document.addEventListener("keyup", handleDocumentKeyUp, true);
    window.addEventListener("blur", clearKeytips);
    queueMicrotask(() => syncTabStops(buttonOrder[0]));

    onCleanup(() => {
      props.registerPrimaryFocusTarget?.(null);
      document.removeEventListener("selectionchange", updateState);
      document.removeEventListener("mousedown", handlePointerDown);
      document.removeEventListener("keydown", handleDocumentKeyDown, true);
      document.removeEventListener("keyup", handleDocumentKeyUp, true);
      window.removeEventListener("blur", clearKeytips);
    });
  });

  const toolbarShellStyle =
    "display:flex;flex-direction:column;gap:12px;padding:12px 16px;border-bottom:1px solid #d9dde6;background:#ffffff;";
  const toolbarRowStyle = "display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;";
  const controlStackStyle = "display:flex;flex-direction:column;gap:6px;min-width:140px;";
  const controlLabelStyle = "font-size:0.8rem;font-weight:600;color:#52607a;";
  const selectStyle =
    "height:42px;padding:0 12px;border:1px solid #c3cad8;border-radius:12px;background:#f7f9fc;color:#172033;font:inherit;";
  const compactSelectStyle =
    "height:34px;padding:0 10px;border:1px solid #c3cad8;border-radius:10px;background:#f7f9fc;color:#172033;font:inherit;font-size:0.9rem;";
  const inputStyle =
    "height:42px;padding:0 12px;border:1px solid #c3cad8;border-radius:12px;background:#f7f9fc;color:#172033;font:inherit;";
  const actionButtonStyle =
    "display:inline-flex;align-items:center;justify-content:center;height:42px;padding:0 14px;border:1px solid #c3cad8;border-radius:12px;background:#f7f9fc;color:#172033;font:inherit;font-weight:600;cursor:pointer;";
  const subtleButtonStyle =
    "display:inline-flex;align-items:center;justify-content:center;height:34px;padding:0 12px;border:1px solid #d9dde6;border-radius:999px;background:#ffffff;color:#4f5d75;font:inherit;font-size:0.9rem;cursor:pointer;";
  const buttonStyle =
    "display:inline-flex;align-items:center;justify-content:center;" +
    "width:44px;height:44px;border:1px solid #c3cad8;border-radius:12px;" +
    "background:#f7f9fc;cursor:pointer;font-size:1rem;font-weight:700;color:#162033;" +
    "transition:background 0.1s,border-color 0.1s,box-shadow 0.1s;";
  const activeStyle =
    "background:#dce8ff;border-color:#3269c8;box-shadow:inset 0 0 0 1px #3269c8;";
  const fontTriggerStyle =
    "display:flex;align-items:center;justify-content:space-between;gap:12px;height:42px;min-width:280px;padding:0 14px;border:1px solid #c3cad8;border-radius:12px;background:#f7f9fc;color:#172033;font:inherit;cursor:pointer;";
  const fontPanelStyle =
    "position:absolute;left:0;top:calc(100% + 8px);z-index:20;width:min(420px,calc(100vw - 48px));" +
    "display:flex;flex-direction:column;gap:12px;padding:14px;border:1px solid #c3cad8;border-radius:16px;background:#ffffff;" +
    "box-shadow:0 22px 40px rgba(15,23,42,0.14);";
  const fontOptionShellStyle =
    "display:flex;align-items:center;gap:8px;width:100%;box-sizing:border-box;padding:4px;border:1px solid #e3e8f1;border-radius:10px;background:#ffffff;";
  const fontOptionSelectedStyle =
    "background:#edf4ff;border-color:#6a95dd;box-shadow:inset 0 0 0 1px #6a95dd;";
  const fontSelectButtonStyle =
    "display:flex;align-items:center;justify-content:space-between;gap:12px;flex:1;min-width:0;border:none;background:transparent;color:#172033;font:inherit;text-align:left;padding:6px 8px;cursor:pointer;";
  const inlineDeleteButtonStyle =
    "display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border:1px solid #d9dde6;border-radius:8px;background:#ffffff;color:#7d2135;font-size:1rem;cursor:pointer;";
  const addMenuStyle =
    "position:absolute;right:-170px;bottom:0;display:flex;flex-direction:column;gap:6px;min-width:150px;padding:8px;border:1px solid #c3cad8;" +
    "border-radius:12px;background:#ffffff;box-shadow:0 18px 32px rgba(15,23,42,0.16);";
  const comboInputStyle =
    "flex:1;height:42px;padding:0 12px;border:1px solid #c3cad8;border-right:none;border-radius:12px 0 0 12px;background:#f7f9fc;color:#172033;font:inherit;min-width:0;";
  const comboButtonStyle =
    "display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;border:1px solid #c3cad8;border-radius:0 12px 12px 0;background:#f7f9fc;color:#52607a;font:inherit;cursor:pointer;";
  const comboMenuStyle =
    "position:absolute;left:0;top:calc(100% + 8px);z-index:15;width:100%;display:flex;flex-direction:column;gap:6px;max-height:240px;overflow:auto;" +
    "padding:8px;border:1px solid #c3cad8;border-radius:12px;background:#ffffff;box-shadow:0 18px 32px rgba(15,23,42,0.14);";
  const comboOptionStyle =
    "display:flex;align-items:center;justify-content:space-between;gap:8px;width:100%;padding:8px 10px;border:1px solid #e3e8f1;border-radius:10px;background:#ffffff;color:#172033;font:inherit;text-align:left;cursor:pointer;";
  const buttonGroupStyle = "display:flex;flex-direction:column;gap:6px;";
  const buttonRowStyle = "display:flex;flex-wrap:wrap;gap:8px;";

  return (
    <div role="toolbar" aria-label="Formatting" style={toolbarShellStyle}>
      <div style={toolbarRowStyle}>
        <div style={`${controlStackStyle}min-width:280px;`}>
          <span style={controlLabelStyle}>Font</span>
          <div style="position:relative;">
            <button
              ref={fontTriggerRef}
              type="button"
              aria-haspopup="dialog"
              aria-expanded={isFontPanelOpen()}
              aria-controls={fontPanelId}
              aria-keyshortcuts={`Alt+${keytipFor("fontFamily")}`}
              tabIndex={-1}
              style={fontTriggerStyle}
              title={`Font picker (Alt+${keytipFor("fontFamily")})`}
              onMouseDown={(event) => event.preventDefault()}
              onKeyDown={handleFontTriggerKeyDown}
              onClick={toggleFontPanel}
            >
              <span style="display:flex;flex-direction:column;align-items:flex-start;min-width:0;">
                <span style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;">
                  {selectedFontFamilyLabel()}
                </span>
                <span style="font-size:0.8rem;color:#52607a;">
                  {selectedFontCategoryLabel()}
                </span>
              </span>
              <span aria-hidden="true" style="font-size:0.8rem;color:#52607a;">
                ▾
              </span>
            </button>
            {renderKeytip("fontFamily")}

            <Show when={isFontPanelOpen()}>
              <div
                ref={fontPanelRef}
                id={fontPanelId}
                role="dialog"
                aria-label="Font picker"
                style={fontPanelStyle}
                onKeyDown={handleFontPanelKeyDown}
              >
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                  <div style="display:flex;flex-direction:column;gap:2px;min-width:0;">
                    <span style="font-size:0.8rem;font-weight:600;color:#52607a;">Current</span>
                    <span
                      style={
                        "font-size:1rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;" +
                        (props.selectedFontFamily === null ? "" : `font-family:${props.selectedFontFamily};`)
                      }
                    >
                      {selectedFontFamilyLabel()}
                    </span>
                  </div>

                  <label style="display:flex;flex-direction:column;gap:4px;align-items:flex-start;">
                    <span style="font-size:0.75rem;font-weight:600;color:#52607a;">Filter</span>
                    <select
                      aria-label="Filter fonts by category"
                      style={compactSelectStyle}
                      value={fontFilter()}
                      onChange={(event) => setFontFilter(event.currentTarget.value as FontFilter)}
                    >
                      <For each={categoryOptions}>
                        {(option) => <option value={option.value}>{option.label}</option>}
                      </For>
                    </select>
                  </label>
                </div>

                <input
                  ref={fontSearchInputRef}
                  type="search"
                  aria-label="Search available fonts"
                  placeholder="Search fonts"
                  style={inputStyle}
                  value={fontSearchQuery()}
                  onInput={(event) => setFontSearchQuery(event.currentTarget.value)}
                  onKeyDown={handleFontSearchKeyDown}
                />

                <div
                  id={fontListId}
                  role="listbox"
                  aria-label="Available fonts"
                  style="display:flex;flex-direction:column;gap:6px;max-height:260px;overflow-x: hidden;padding-right:2px;"
                >
                  <Show
                    when={visibleFonts().length}
                    fallback={
                      <p style="margin:0;padding:10px 12px;color:#52607a;font-size:0.9rem;">
                        No fonts match that search.
                      </p>
                    }
                  >
                    <For each={visibleFonts()}>
                      {(font, index) => (
                        <div
                             style={
                             fontOptionShellStyle +
                             (font.family === props.selectedFontFamily ? fontOptionSelectedStyle : "")
                           }
                         >
                          <button
                            ref={(element) => {
                              fontOptionRefs[index()] = element;
                            }}
                             type="button"
                             role="option"
                             aria-selected={font.family === props.selectedFontFamily}
                            style={fontSelectButtonStyle}
                            onMouseDown={(event) => event.preventDefault()}
                            onKeyDown={handleFontOptionKeyDown}
                            onClick={() => selectFont(font.family)}
                          >
                            <span style="display:flex;flex-direction:column;min-width:0;">
                              <span
                                style={`font-family:${font.family};font-size:1rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;`}
                              >
                                {font.family}
                              </span>
                              <span style="font-size:0.78rem;color:#52607a;">
                                {FONT_CATEGORY_LABELS[font.category]}
                              </span>
                            </span>
                          </button>
                          <Show when={font.removable && font.source === "uploaded"}>
                            <button
                              type="button"
                              aria-label={`Remove imported font ${font.family}`}
                              title={`Remove imported font ${font.family}`}
                              style={inlineDeleteButtonStyle}
                              onMouseDown={(event) => {
                                event.preventDefault();
                                event.stopPropagation();
                              }}
                              onClick={(event) => {
                                event.preventDefault();
                                event.stopPropagation();
                                handleRemoveFont(font.id, font.family);
                              }}
                            >
                              ×
                            </button>
                          </Show>
                        </div>
                      )}
                    </For>
                  </Show>
                </div>

                <Show when={fontLibraryMode() === "google"}>
                  <div style="display:flex;flex-direction:column;gap:8px;padding:10px;border:1px solid #e3e8f1;border-radius:12px;background:#f8faff;">
                    <span style="font-size:0.8rem;font-weight:600;color:#52607a;">
                      Add from Google Fonts
                    </span>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                      <input
                        ref={googleSearchInputRef}
                        type="search"
                        aria-label="Search validated Google Fonts"
                        placeholder="Search Google Fonts"
                        style={`flex:1;min-width:180px;${inputStyle}`}
                        value={googleQuery()}
                        onInput={(event) => setGoogleQuery(event.currentTarget.value)}
                        onKeyDown={(event) => {
                          if (event.key === "Enter") {
                            event.preventDefault();
                            void handleGoogleFontSearch();
                          }
                        }}
                      />
                      <button
                        type="button"
                        style={actionButtonStyle}
                        disabled={isSearchingGoogleFonts()}
                        onMouseDown={(event) => event.preventDefault()}
                        onClick={() => void handleGoogleFontSearch()}
                      >
                        {isSearchingGoogleFonts() ? "Searching…" : "Search"}
                      </button>
                    </div>

                    <Show when={googleResults().length}>
                      <div style="display:flex;flex-wrap:wrap;gap:8px;">
                        <For each={googleResults()}>
                          {(font) => (
                            <button
                              type="button"
                              style={subtleButtonStyle}
                              onMouseDown={(event) => event.preventDefault()}
                              onClick={() => {
                                if (knownFamilies().has(font.family)) {
                                  selectFont(font.family);
                                  return;
                                }

                                props.onAddCatalogFont(font);
                                closeFontPanel();
                                queueMicrotask(() => focusEditor());
                              }}
                            >
                              {font.family} · {knownFamilies().has(font.family) ? "Select" : "Add"}
                            </button>
                          )}
                        </For>
                      </div>
                    </Show>
                  </div>
                </Show>

                <Show when={googleSearchError()}>
                  <p style="margin:0;color:#a94442;font-size:0.85rem;">{googleSearchError()}</p>
                </Show>

                <div style="display:flex;justify-content:flex-end;position:relative;">
                  <button
                    type="button"
                    aria-label="Add fonts"
                    aria-haspopup="menu"
                    aria-expanded={isAddMenuOpen()}
                    style={`${buttonStyle}width:38px;height:38px;border-radius:10px;${!canAddFonts() ? "opacity:0.6;cursor:not-allowed;" : ""}`}
                    disabled={!canAddFonts()}
                    title={canAddFonts() ? "Add fonts" : "Font installs are only available on desktop."}
                    onMouseDown={(event) => event.preventDefault()}
                    onClick={toggleAddMenu}
                  >
                    +
                  </button>

                  <Show when={isAddMenuOpen()}>
                    <div role="menu" aria-label="Add fonts" style={addMenuStyle}>
                      <button
                        ref={(element) => {
                          addMenuItemRefs[0] = element;
                        }}
                        type="button"
                        role="menuitem"
                        disabled={!supportsLocalFonts()}
                        style={`${actionButtonStyle}height:38px;justify-content:flex-start;`}
                        onMouseDown={(event) => event.preventDefault()}
                        onKeyDown={handleAddMenuKeyDown}
                        onClick={() => handleAddMenuChoice("local")}
                      >
                        From Local
                      </button>
                      <button
                        ref={(element) => {
                          addMenuItemRefs[1] = element;
                        }}
                        type="button"
                        role="menuitem"
                        disabled={!supportsGoogleFonts()}
                        style={`${actionButtonStyle}height:38px;justify-content:flex-start;`}
                        onMouseDown={(event) => event.preventDefault()}
                        onKeyDown={handleAddMenuKeyDown}
                        onClick={() => handleAddMenuChoice("google")}
                      >
                        From Google Fonts
                      </button>
                    </div>
                  </Show>
                  <input
                    ref={uploadInputRef}
                    type="file"
                    accept=".ttf,.otf,.woff,.woff2"
                    multiple={true}
                    style="display:none"
                    onChange={(event) => void handleUploadedFonts(event.currentTarget.files)}
                  />
                </div>
              </div>
            </Show>
          </div>
        </div>

        <div style={`${controlStackStyle}min-width:160px;`}>
          <span style={controlLabelStyle}>Size</span>
          <div ref={fontSizeControlRef} style="position:relative;">
            <div style="display:flex;">
              <input
                ref={fontSizeInputRef}
                type="text"
                aria-label="Font size"
                aria-controls={fontSizeListId}
                aria-expanded={isFontSizeMenuOpen()}
                aria-keyshortcuts={`Alt+${keytipFor("fontSize")}`}
                value={fontSizeDraft()}
                placeholder={props.selectedFontSize === null ? MIXED_FORMATTING_LABEL : undefined}
                style={comboInputStyle}
                tabIndex={-1}
                title={`Font size (Alt+${keytipFor("fontSize")})`}
                onInput={(event) => {
                  setFontSizeDraft(event.currentTarget.value);
                  setFontSizeError("");
                  setIsFontSizeMenuOpen(true);
                }}
                onFocus={() => setIsFontSizeMenuOpen(true)}
                onBlur={(event) =>
                  handleFontSizeCommit(event.currentTarget.value, { focusEditor: false })
                }
                onKeyDown={handleFontSizeInputKeyDown}
              />
              <button
                type="button"
                aria-label="Show font sizes"
                style={comboButtonStyle}
                tabIndex={-1}
                onMouseDown={(event) => event.preventDefault()}
                onClick={() => {
                  setIsFontSizeMenuOpen((open) => !open);
                  if (!isFontSizeMenuOpen()) {
                    queueMicrotask(() => fontSizeInputRef?.focus());
                  }
                }}
              >
                ▾
              </button>
            </div>
            {renderKeytip("fontSize")}
            <Show when={isFontSizeMenuOpen()}>
              <div id={fontSizeListId} role="listbox" aria-label="Font sizes" style={comboMenuStyle}>
                <For each={visibleFontSizes()}>
                  {(size) => (
                    <button
                      type="button"
                      style={comboOptionStyle}
                      onMouseDown={(event) => event.preventDefault()}
                      onClick={() => handleFontSizeCommit(String(size))}
                    >
                      <span>{size} pt</span>
                      <Show when={props.selectedFontSize !== null && size === props.selectedFontSize}>
                        <span aria-hidden="true">✓</span>
                      </Show>
                    </button>
                  )}
                </For>
              </div>
            </Show>
          </div>
          <Show when={fontSizeError()}>
            <span role="alert" style="font-size:0.75rem;color:#a94442;margin-top:2px;">
              {fontSizeError()}
            </span>
          </Show>
        </div>

        <div style={`${controlStackStyle}min-width:170px;`}>
          <span style={controlLabelStyle}>Line spacing</span>
          <div ref={lineSpacingControlRef} style="position:relative;">
            <div style="display:flex;">
              <input
                ref={lineSpacingInputRef}
                type="text"
                aria-label="Line spacing"
                aria-controls={lineSpacingListId}
                aria-expanded={isLineSpacingMenuOpen()}
                aria-keyshortcuts={`Alt+${keytipFor("lineSpacing")}`}
                value={lineSpacingDraft()}
                placeholder={props.selectedLineSpacing === null ? MIXED_FORMATTING_LABEL : undefined}
                style={comboInputStyle}
                tabIndex={-1}
                title={`Line spacing (Alt+${keytipFor("lineSpacing")})`}
                onInput={(event) => {
                  setLineSpacingDraft(event.currentTarget.value);
                  setLineSpacingError("");
                  setIsLineSpacingMenuOpen(true);
                }}
                onFocus={() => setIsLineSpacingMenuOpen(true)}
                onBlur={(event) =>
                  handleLineSpacingCommit(event.currentTarget.value, { focusEditor: false })
                }
                onKeyDown={handleLineSpacingInputKeyDown}
              />
              <button
                type="button"
                aria-label="Show line spacing options"
                style={comboButtonStyle}
                tabIndex={-1}
                onMouseDown={(event) => event.preventDefault()}
                onClick={() => {
                  setIsLineSpacingMenuOpen((open) => !open);
                  if (!isLineSpacingMenuOpen()) {
                    queueMicrotask(() => lineSpacingInputRef?.focus());
                  }
                }}
              >
                ▾
              </button>
            </div>
            {renderKeytip("lineSpacing")}
            <Show when={isLineSpacingMenuOpen()}>
              <div
                id={lineSpacingListId}
                role="listbox"
                aria-label="Line spacing options"
                style={comboMenuStyle}
              >
                <For each={visibleLineSpacingOptions()}>
                  {(value) => (
                    <button
                      type="button"
                      style={comboOptionStyle}
                      onMouseDown={(event) => event.preventDefault()}
                      onClick={() => handleLineSpacingCommit(formatLineSpacingValue(value))}
                    >
                      <span>{labelLineSpacingOption(value)}</span>
                      <Show
                        when={
                          props.selectedLineSpacing !== null &&
                          formatLineSpacingValue(value) === formatLineSpacingValue(props.selectedLineSpacing)
                        }
                      >
                        <span aria-hidden="true">✓</span>
                      </Show>
                    </button>
                  )}
                </For>
              </div>
            </Show>
          </div>
          <Show when={lineSpacingError()}>
            <span role="alert" style="font-size:0.75rem;color:#a94442;margin-top:2px;">
              {lineSpacingError()}
            </span>
          </Show>
        </div>
      </div>

      <div style={toolbarRowStyle} onKeyDown={handleButtonRowKeyDown}>
        <div style={buttonGroupStyle}>
          <span style={controlLabelStyle}>Style</span>
          <div style={buttonRowStyle}>
            <For each={inlineFormattingActions}>
              {(action) => (
                <div style="position:relative;display:inline-flex;">
                  {renderKeytip(action.id)}
                  <button
                    ref={(element) => {
                      buttonRefs[action.id] = element;
                    }}
                    type="button"
                    data-toolbar-button-id={action.id}
                    aria-label={action.label}
                    aria-pressed={state()[action.id as InlineFormattingId]}
                    aria-keyshortcuts={`${action.ariaShortcut} Alt+${keytipFor(action.id)}`}
                    title={`${action.label} (${action.shortcut}, Alt+${keytipFor(action.id)})`}
                    tabIndex={-1}
                    style={buttonStyle + (state()[action.id as InlineFormattingId] ? activeStyle : "")}
                    onMouseDown={(event) => event.preventDefault()}
                    onFocus={() => syncTabStops(action.id)}
                    onClick={() => execInlineFormat(action.command)}
                  >
                    {action.content}
                  </button>
                </div>
              )}
            </For>
          </div>
        </div>

        <div style={buttonGroupStyle}>
          <span style={controlLabelStyle}>Align</span>
          <div style={buttonRowStyle}>
            <For each={alignmentActions}>
              {(action) => (
                <div style="position:relative;display:inline-flex;">
                  {renderKeytip(action.id)}
                  <button
                    ref={(element) => {
                      buttonRefs[action.id] = element;
                    }}
                    type="button"
                    data-toolbar-button-id={action.id}
                    aria-label={action.label}
                    aria-pressed={props.selectedAlignment === action.id}
                    aria-keyshortcuts={`Alt+${keytipFor(action.id)}`}
                    title={`${action.label} (Alt+${keytipFor(action.id)})`}
                    tabIndex={-1}
                    style={buttonStyle + (props.selectedAlignment === action.id ? activeStyle : "")}
                    onMouseDown={(event) => event.preventDefault()}
                    onFocus={() => syncTabStops(action.id)}
                    onClick={() => commitAlignmentChange(action.id)}
                  >
                    {action.content}
                  </button>
                </div>
              )}
            </For>
          </div>
        </div>

        <div style={buttonGroupStyle}>
          <span style={controlLabelStyle}>Indent</span>
          <div style={buttonRowStyle}>
            <div style="position:relative;display:inline-flex;">
              {renderKeytip("indent")}
              <button
                ref={(element) => {
                  buttonRefs.indent = element;
                }}
                type="button"
                data-toolbar-button-id="indent"
                aria-label="Indent selection"
                aria-keyshortcuts={`Alt+${keytipFor("indent")}`}
                title={`Indent selection (Tab in editor, Ctrl+], Alt+${keytipFor("indent")})`}
                tabIndex={-1}
                style={buttonStyle}
                onMouseDown={(event) => event.preventDefault()}
                onFocus={() => syncTabStops("indent")}
                onClick={commitIndent}
              >
                ⇥
              </button>
            </div>
            <div style="position:relative;display:inline-flex;">
              {renderKeytip("outdent")}
              <button
                ref={(element) => {
                  buttonRefs.outdent = element;
                }}
                type="button"
                data-toolbar-button-id="outdent"
                aria-label="Outdent selection"
                aria-keyshortcuts={`Alt+${keytipFor("outdent")}`}
                title={`Outdent selection (Shift+Tab in editor, Ctrl+[, Alt+${keytipFor("outdent")})`}
                tabIndex={-1}
                style={buttonStyle}
                onMouseDown={(event) => event.preventDefault()}
                onFocus={() => syncTabStops("outdent")}
                onClick={commitOutdent}
              >
                ⇤
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
